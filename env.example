# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Usuário e senha do cluster MongoDB Atlas
DB_USER=seu_usuario_mongodb
DB_PASSWORD=sua_senha_mongodb

# Nome do banco de dados
MONGO_DB=projeto_ocup_desocup

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Chave da API OpenAI (usada pelo chatbot Streamlit)
OPENAI_API_KEY=sk-...

# ── Instruções ─────────────────────────────────────────────────────────────────
# 1. Copie este arquivo para .env:
#       cp .env.example .env
# 2. Preencha os valores reais no .env
# 3. NUNCA suba o .env para o GitHub — ele já está no .gitignore
